{
  "name": "@btr-supply/btr-prime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["shared", "dashboard"],
  "scripts": {
    "fmt": "bunx oxfmt src/ tests/ shared/ scripts/ dashboard/src/lib/",
    "fmt:check": "bunx oxfmt --check src/ tests/ shared/ scripts/ dashboard/src/lib/",
    "lint": "bunx oxlint src/ tests/ shared/ scripts/ dashboard/src/",
    "lint:fix": "bunx oxlint --fix src/ tests/ shared/ scripts/ dashboard/src/",
    "typecheck": "bunx tsgo --noEmit",
    "check": "bun run fmt:check && bun run lint && bun run typecheck",
    "dev:infra": "docker compose up -d dragonfly openobserve",
    "dev:api": "bun --watch src/api-server.ts",
    "dev:back": "bun --watch src/index.ts",
    "dev:front": "bun run --cwd dashboard dev",
    "dev": "bash scripts/dev.sh",
    "start": "bun src/index.ts",
    "orchestrate": "bun src/orchestrator.ts",
    "prod": "docker compose --profile prod up -d --build",
    "prod:down": "docker compose --profile prod down",
    "test": "bun run check && bun test",
    "test:integration": "INTEGRATION=true bun test"
  },
  "dependencies": {
    "viem": "^2.23.0",
    "ccxt": "^4.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "puppeteer": "^24.37.5"
  }
}
